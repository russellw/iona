; SHORT-CIRCUIT LOGICAL OPERATORS: `AND`, `OR`, `NOT`.
;
; THEY ARE CONDITION-ONLY CONTROL-FLOW WORDS. EACH ONE SHORT-CIRCUITS, SO A
; GUARDED CALL ON THE DEAD SIDE IS NEVER EVALUATED -- `BOOM` MUST STAY SILENT.

!BOOM
    "BOOM: SHORT-CIRCUIT FAILED!" PRINT
    0 @

!MAIN
    5 0 > 5 100 < AND ?            ; BOTH TRUE
        "AND-TRUE" PRINT

    0 1 > BOOM 0 > AND ?           ; LEFT FALSE: BOOM MUST BE SKIPPED
        "UNREACHABLE" PRINT
    /
        "AND-FALSE" PRINT

    0 1 > 7 0 > OR ?               ; RIGHT TRUE
        "OR-TRUE" PRINT

    1 0 > BOOM 0 > OR ?            ; LEFT TRUE: BOOM MUST BE SKIPPED
        "OR-SHORT" PRINT

    1 0 < NOT ?                    ; NOT FALSE -> TRUE
        "NOT-TRUE" PRINT

    50 0 > 50 100 < AND NOT ?      ; NOT (TRUE) -> FALSE
        "UNREACHABLE" PRINT
    /
        "NOT-FALSE" PRINT

    "DONE" PRINT
