; BITWISE OPERATORS (VALUE OPERATORS ON INTEGER TYPES B/W):
;   BAND &   BOR |   BXOR ^   BSHL <<   BSHR >>   BNOT ~ (unary)
; They are word-spelled with a `B` prefix, distinct from the condition-only
; logical AND/OR/NOT.

!MAIN W
    !F W
    5 F!                       ; 0b101

    F 2 BOR PRINT              ; 5 | 2  = 7
    F 4 BAND PRINT             ; 5 & 4  = 4
    F 1 BXOR PRINT             ; 5 ^ 1  = 4
    1 4 BSHL PRINT             ; 1 << 4 = 16
    255 4 BSHR PRINT           ; 255 >> 4 = 15
    5 BNOT 255 BAND PRINT      ; (~5) & 255 = 250

    F 1 BAND 0 <> ?            ; bit 0 set -> odd
        "ODD" PRINT
    /
        "EVEN" PRINT
