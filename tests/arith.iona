# EXERCISES ARITHMETIC, COMPARISONS, IF/ELSE, AND NESTED CALLS.

!MAX A B
    A B < IF
        B RETURN
    ELSE
        A RETURN

!MAIN
    2 3 4 * + PRINT          # 2 + (3*4) = 14
    20 7 % PRINT             # 6
    100 9 / PRINT            # 11
    3 8 MAX PRINT            # 8
    8 3 MAX PRINT            # 8
    5 5 = IF                 # EQUALITY IS `=`
        "EQUAL" PRINT
    ELSE
        "NO" PRINT
