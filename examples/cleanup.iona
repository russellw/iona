# Iona's `return` sets the result but does NOT exit the function. Execution
# continues to the end, so resource-cleanup statements placed after a `return`
# always get a chance to run -- the language has no destructors.

def read_squared x:
    "open file" print
    x x * return          # set the result we want to hand back
    "close file" print    # still runs, even though we already "returned"

def main:
    5 read_squared print
